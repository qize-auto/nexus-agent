# NexusAgent v0.1.0 — Environment Variables / 环境变量配置模板
# Copy this file to .env and fill in your API keys / 复制此文件为 .env 并填入密钥

# ═══════════════════════════════════════════════════════════════
# Provider Selection / 默认提供商选择
# ═══════════════════════════════════════════════════════════════
NEXUS_LLM_PROVIDER=deepseek
NEXUS_DEFAULT_MODEL=deepseek-chat

# ═══════════════════════════════════════════════════════════════
# 🇨🇳 Domestic Providers — 国内大模型
# ═══════════════════════════════════════════════════════════════

# ── DeepSeek ──
# Docs: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ── Moonshot / Kimi (月之暗面) ──
# Docs: https://platform.moonshot.cn/  (品牌迁移中，新文档见 https://platform.kimi.com/)
# ⚠️ 两套 API Key 体系说明 / Two independent API key systems:
#   - MOONSHOT_API_KEY: 适用于 Moonshot 开放平台获取的密钥
#   - KIMI_API_KEY: 适用于 Kimi 品牌渠道获取的密钥
#   两者互不通用，但系统会在本 provider 的 key 缺失时自动尝试另一套 key 作为回退。
# 当前可用模型 / Available models: moonshot-v1-8k/32k/128k, kimi-k2.6, kimi-k2.5, kimi-k2-thinking
MOONSHOT_API_KEY=sk-your-moonshot-key-here
KIMI_API_KEY=sk-your-kimi-key-here

# ── Alibaba Qwen (通义千问) ──
# Docs: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# ── Baidu Wenxin (文心一言) ──
# Docs: https://qianfan.baidu.com/
QIANFAN_API_KEY=your-qianfan-key-here

# ── Zhipu GLM (智谱) ──
# Docs: https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-key-here

# ── Xiaomi Mi-LLM (小米) ──
# Docs: https://api.xiaomi.ai/
XIAOMI_API_KEY=sk-your-xiaomi-key-here

# ═══════════════════════════════════════════════════════════════
# 🌍 International Providers — 国外大模型
# ═══════════════════════════════════════════════════════════════

# ── OpenAI ──
# Docs: https://platform.openai.com/
OPENAI_API_KEY=sk-your-openai-key-here

# ── Anthropic Claude ──
# Docs: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-your-anthropic-key-here

# ── Google Gemini ──
# Docs: https://aistudio.google.com/
GOOGLE_API_KEY=your-google-key-here

# ── Azure OpenAI ──
# You must also configure AZURE_OPENAI_ENDPOINT and AZURE_OPENAI_API_VERSION
AZURE_OPENAI_API_KEY=your-azure-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Groq ──
# Docs: https://console.groq.com/
GROQ_API_KEY=gsk-your-groq-key-here

# ── Together AI ──
# Docs: https://api.together.xyz/
TOGETHER_API_KEY=your-together-key-here

# ═══════════════════════════════════════════════════════════════
# Advanced Configuration / 高级配置
# ═══════════════════════════════════════════════════════════════
# NEXUS_HOME=C:\Users\YourName\.nexusagent
# NEXUS_DEBUG=false
# NEXUS_CONFIG=./config.yaml
# NEXUS_MASTER_KEY=  # Base64 encoded 32-byte key; leave empty for ephemeral key
