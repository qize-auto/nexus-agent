# NexusAgent v4.0+ — 生产环境配置模板
# 复制为 .env.production 并填入真实值
# 警告: 切勿将含真实密钥的 .env 文件提交到 Git

# ═══════════════════════════════════════════════════════════════
# LLM Provider 配置 (至少配置一个)
# ═══════════════════════════════════════════════════════════════

# DeepSeek (推荐国内)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Moonshot / Kimi
MOONSHOT_API_KEY=your_moonshot_api_key_here

# OpenAI (国际)
OPENAI_API_KEY=your_openai_api_key_here

# Ollama (本地运行，无需 API key)
OLLAMA_HOST=http://localhost:11434
OLLAMA_API_KEY=

# ═══════════════════════════════════════════════════════════════
# 默认模型配置
# ═══════════════════════════════════════════════════════════════
DEFAULT_PROVIDER=deepseek
DEFAULT_MODEL=deepseek-chat

# ═══════════════════════════════════════════════════════════════
# 服务配置
# ═══════════════════════════════════════════════════════════════
NEXUS_HOST=0.0.0.0
NEXUS_PORT=8080
NEXUS_DEBUG=false
NEXUS_HOME=/app/data

# ═══════════════════════════════════════════════════════════════
# Redis (可选，用于分布式限流和消息队列)
# ═══════════════════════════════════════════════════════════════
REDIS_URL=redis://nexusagent_redis:6379/0

# ═══════════════════════════════════════════════════════════════
# SearXNG 本地搜索
# ═══════════════════════════════════════════════════════════════
SEARXNG_HOST=http://nexusagent_searxng:8080

# ═══════════════════════════════════════════════════════════════
# 安全配置
# ═══════════════════════════════════════════════════════════════
NEXUS_ALLOW_FILE_OPS=0
NEXUS_ENCRYPTION_KEY=
NEXUS_DATA_CLASSIFICATION=MEDIUM

# ═══════════════════════════════════════════════════════════════
# 监控与日志
# ═══════════════════════════════════════════════════════════════
NEXUS_TELEMETRY_ENABLED=false
NEXUS_ANALYTICS_ENABLED=false
NEXUS_CRASH_REPORTING=false

# ═══════════════════════════════════════════════════════════════
# 备份配置
# ═══════════════════════════════════════════════════════════════
NEXUS_BACKUP_DIR=/app/data/backups
NEXUS_MAX_BACKUPS=7
